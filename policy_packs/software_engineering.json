{
  "policy_version": "software-engineering-v1",
  "role_permissions": {
    "developer": ["read_file", "write_file", "run_tests", "write_report"],
    "code_reviewer": ["read_file", "run_tests", "write_report"],
    "release_manager": ["read_file", "run_tests", "deploy", "write_report", "send_external"]
  },
  "approval_actions": ["deploy", "delete", "execute_shell", "send_external"],
  "blocked_tools": ["raw_shell"],
  "block_risk_at": 80,
  "require_approval_risk_at": 50
}
